local SuperBypass = {}
do
    local p = game.Players.LocalPlayer
    local ws = game:GetService("Workspace")
    local rs = game:GetService("ReplicatedStorage")
    local rf = game:GetService("ReplicatedFirst")
    local ls = game:GetService("LogService")
    local ps = p:WaitForChild("PlayerScripts")
    local active = false
    local originalUserId = p.UserId
    local fakeUserId = 1

    function SuperBypass:cleanEnvironment()
        pcall(function()
            for _, obj in ipairs(ws:GetChildren()) do
                if obj:IsA("Folder") and (obj.Name:lower():find("log") or obj.Name:lower():find("ac") or obj.Name:lower():find("anticheat")) then
                    obj:Destroy()
                end
            end
            local pf = p:FindFirstChild("DetectionLogs")
            if pf then pf:Destroy() end
            for _, container in ipairs({rf, rs}) do
                for _, obj in ipairs(container:GetDescendants()) do
                    if obj:IsA("ModuleScript") and (obj.Name:lower():find("anticheat") or obj.Name:lower():find("ac") or obj.Name:lower():find("denys")) then
                        obj:Destroy()
                    end
                end
            end
        end)
    end

    function SuperBypass:hookMetamethods()
        local mt = getrawmetatable(game)
        local oldNamecall = mt.__namecall
        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            local args = {...}
            if method == "InvokeServer" or method == "FireServer" then
                local name = tostring(self):lower()
                if name:find("ban") or name:find("kick") or name:find("report") or name:find("detect") then
                    return nil
                end
            end
            if method == "GetObjects" and args[1] and tostring(args[1]):find("anticheat") then
                return {}
            end
            return oldNamecall(self, ...)
        end)

        local humMt = getrawmetatable(Instance.new("Humanoid"))
        local oldHumIndex = humMt.__index
        humMt.__index = newcclosure(function(t, k)
            if active and (k == "WalkSpeed" or k == "JumpPower") then
                return 16
            end
            return oldHumIndex(t, k)
        end)
    end

    function SuperBypass:disablePlayerScripts()
        for _, script in ipairs(ps:GetDescendants()) do
            if script:IsA("LocalScript") or script:IsA("ModuleScript") then
                local name = script.Name:lower()
                if name:find("anticheat") or name:find("ac") or name:find("denys") or name:find("detector") then
                    pcall(function() script.Disabled = true end)
                    pcall(function() script:Destroy() end)
                end
            end
        end
    end

    function SuperBypass:spoofUserId()
        local oldRequest = request or http_request or syn.request
        if oldRequest then
            hookfunction(oldRequest, function(req)
                if req.Url:find("roblox") then
                    req.Body = req.Body:gsub("userId="..originalUserId, "userId="..fakeUserId)
                    req.Body = req.Body:gsub("%"..originalUserId, "%"..fakeUserId)
                end
                return oldRequest(req)
            end)
        end
    end

    function SuperBypass:startLogCleaner()
        task.spawn(function()
            while active do
                pcall(function() ls:ClearOutput() end)
                task.wait(30)
            end
        end)
    end

    function SuperBypass:enable()
        if active then return end
        active = true
        self:cleanEnvironment()
        self:hookMetamethods()
        self:disablePlayerScripts()
        self:spoofUserId()
        self:startLogCleaner()
        WindUI:Notify({ Title = "Super Bypass 100%", Content = "Modo Dios activado. ¡Indetectable!", Duration = 3 })
    end
end
Bypass = SuperBypass

