-- ANTI-AFK
-- ==============================================================================
local cam = workspace.CurrentCamera
local uis = game:GetService("UserInputService")
local antiAFKActive = false

local function moveCamera()
    if not antiAFKActive then return end
    local cf = cam.CFrame
    cam.CFrame = cf * CFrame.Angles(0, math.rad(1), 0)
    task.wait(0.05)
    cam.CFrame = cf * CFrame.Angles(0, math.rad(-1), 0)
    task.wait(0.05)
    cam.CFrame = cf
end

local function pressW()
    if not antiAFKActive then return end
    vim:SendKeyEvent(true, "W", false, game)
    task.wait(0.05)
    vim:SendKeyEvent(false, "W", false, game)
end

local function moveMouse()
    if not antiAFKActive then return end
    local pos = uis:GetMouseLocation()
    vim:SendMouseMovementEvent(pos.X + 1, pos.Y, 0, game)
    task.wait(0.05)
    vim:SendMouseMovementEvent(pos.X, pos.Y, 0, game)
end

local function antiAFKLoop()
    while antiAFKActive do
        moveCamera()
        pressW()
        moveMouse()
        task.wait(math.random(40, 70))
    end
end

_G.zHub.antiAFK = {
    toggle = function()
        antiAFKActive = not antiAFKActive
        if antiAFKActive then
            task.spawn(antiAFKLoop)
            WindUI:Notify({ Title = "Anti-AFK", Content = "Activado", Duration = 2 })
        else
            WindUI:Notify({ Title = "Anti-AFK", Content = "Desactivado", Duration = 2 })
        end
    end
}

