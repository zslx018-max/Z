    hrp.CFrame = CFrame.new(-1843, 3, 8)
    hrp.Anchored = false
    task.wait(0.1)
end

local function SmartBuy()
    local marketPos = CFrame.new(-1843, 3, 8)
    local endTime = tick() + 15
    local lastTeleport = tick()
    while not hasAllItems() and tick() < endTime and autoFarm do
        if tick() - lastTeleport >= 0.5 then
            hrp.Anchored = true
            hrp.CFrame = marketPos
            hrp.Anchored = false
            lastTeleport = tick()
        end
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") then
                local pPart = obj.Parent:IsA("BasePart") and obj.Parent or obj.Parent.Parent
                if pPart and pPart:IsA("BasePart") and (pPart.Position - hrp.Position).Magnitude <= 18 then
                    local txt = (obj.ObjectText .. obj.ActionText):lower()
                    for item, maxQty in pairs(items) do
                        if txt:find(item:lower()) and getQty(item) < maxQty then
                            obj.HoldDuration = 0
                            fireproximityprompt(obj)
                            task.wait()
                        end
                    end
                end
            end
        end
        task.wait(0.03)
    end
end

local function SmartSell()
    local endTime = tick() + 8
    while not hasNoItems() and tick() < endTime and autoFarm do
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") then
                local pPart = obj.Parent:IsA("BasePart") and obj.Parent or obj.Parent.Parent
                if pPart and pPart:IsA("BasePart") and (pPart.Position - hrp.Position).Magnitude <= 18 then
                    local txt = (obj.ObjectText .. obj.ActionText):lower()
                    if txt:find("sell") or txt:find("smuggle") then
                        obj.HoldDuration = 0; fireproximityprompt(obj); task.wait(0.05)
                    end
                end
            end
        end
        task.wait(0.1)
    end
end

local function forceUIClick(textoBoton)
    for _, gui in pairs(p.PlayerGui:GetDescendants()) do
        if gui:IsA("TextButton") and gui.Visible and gui.AbsolutePosition.X > 0 then
            if gui.Text:lower():find(textoBoton:lower()) then
                local x = gui.AbsolutePosition.X + (gui.AbsoluteSize.X / 2)
                local y = gui.AbsolutePosition.Y + (gui.AbsoluteSize.Y / 2) + 36
                vim:SendMouseButtonEvent(x, y, 0, true, game, 1)
                task.wait(0.05)
                vim:SendMouseButtonEvent(x, y, 0, false, game, 1)
                return true
            end
        end
    end
    return false
end

local function AutoGetCarPremium()
    if hum.SeatPart then miAsiento = hum.SeatPart; return end
    local carSpawnPos = CFrame.new(-1947, 3.5, 55)
    local startTime = tick()
    local maxDuration = 15
    local lastTeleport = tick()
    while not hum.SeatPart and tick() - startTime < maxDuration and autoFarm do
        if tick() - lastTeleport >= 0.5 then
            hrp.Anchored = true
            hrp.CFrame = carSpawnPos
            hrp.Anchored = false
            lastTeleport = tick()
        end
        forceUIClick("select")
        task.wait(0.1)
        forceUIClick("spawn")
        task.wait(0.1)
        for _, obj in pairs(workspace:GetDescendants()) do
            if (obj:IsA("VehicleSeat") or obj:IsA("Seat")) and (obj.Position - hrp.Position).Magnitude < 30 then
                obj:Sit(hum)
                if hum.SeatPart then miAsiento = hum.SeatPart; return end
            end
        end
        task.wait(0.2)
    end
    if not hum.SeatPart then task.wait(1) AutoGetCarPremium() end
end

local function mainLoop()
    while true do
        task.wait(0.2)
        if autoFarm then
            pcall(function()
                refreshVars()
                if not miAsiento or not miAsiento.Parent then
                    if hum.SeatPart then miAsiento = hum.SeatPart else AutoGetCarPremium() end
                    if not miAsiento then return end
                end
                EnsureSit()
                safeVehicleTP(CFrame.new(-1849, 1, 25), true)
                safeExitSeat(Vector3.new(-1843, 3, 8))
                task.wait(0.1)
                SmartWash()
                SmartBuy()
                EnsureSit()
                safeVehicleTP(CFrame.new(3514, 14, -723) * CFrame.Angles(0, math.rad(26), 0), false)
                safeExitSeat(Vector3.new(3506, 4, -744))
                task.wait(0.1)
                SmartSell()
                EnsureSit()
            end)
        end
    end
end

task.spawn(mainLoop)

