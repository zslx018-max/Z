                line.Visible = true
            else
                line.Visible = false
            end
        end)
        if not success then line.Visible = false end
    end

    Players.PlayerRemoving:Connect(Z_ClearSkeleton)

    -- // 🔄 MOTOR DE RENDER SKELETON // --
    RunService.RenderStepped:Connect(function()
        local mySide = GetSideSkel(LP)
        local color = _G.Z_Skeleton_Color

        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LP then
                local char = player.Character
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                local hrp = char and char:FindFirstChild("HumanoidRootPart")

                -- 1. VALIDACIÓN BÁSICA
                if _G.Z_Skeleton_Enabled and char and char.Parent and hum and hum.Health > 0 and hrp then
                    
                    -- 2. 🤖 SMART TEAM CHECK (FULANITO 4)
                    if _G.Z_Skeleton_TeamCheck then
                        local targetSide = GetSideSkel(player)
                        if mySide == targetSide and mySide ~= "Neutral" then
                            if Z_Skeleton_Data[player] then
                                for _, g in pairs(Z_Skeleton_Data[player]) do for _, l in pairs(g) do l.Visible = false end end
                            end
                            continue
                        end
                    end

                    if not Z_Skeleton_Data[player] then Z_Skeleton_Data[player] = Z_BuildSkeleton() end
                    local skel = Z_Skeleton_Data[player]

                    -- DETECCIÓN R15 / R6
                    if char:FindFirstChild("UpperTorso") then -- R15
                        Z_JoinNodes(skel.Spine[1], char.Head, char.UpperTorso, color)
                        Z_JoinNodes(skel.Spine[2], char.UpperTorso, char.LowerTorso, color)
                        Z_JoinNodes(skel.Arms[1], char.UpperTorso, char.LeftUpperArm, color)
                        Z_JoinNodes(skel.Arms[2], char.LeftUpperArm, char.LeftHand, color)
                        Z_JoinNodes(skel.Arms[3], char.UpperTorso, char.RightUpperArm, color)
                        Z_JoinNodes(skel.Arms[4], char.RightUpperArm, char.RightHand, color)
                        Z_JoinNodes(skel.Legs[1], char.LowerTorso, char.LeftUpperLeg, color)
                        Z_JoinNodes(skel.Legs[2], char.LeftUpperLeg, char.LeftFoot, color)
                        Z_JoinNodes(skel.Legs[3], char.LowerTorso, char.RightUpperLeg, color)
                        Z_JoinNodes(skel.Legs[4], char.RightUpperLeg, char.RightFoot, color)
                    elseif char:FindFirstChild("Torso") then -- R6
                        Z_JoinNodes(skel.Spine[1], char.Head, char.Torso, color)
                        Z_JoinNodes(skel.Arms[1], char.Torso, char["Left Arm"], color)
                        Z_JoinNodes(skel.Arms[3], char.Torso, char["Right Arm"], color)
                        Z_JoinNodes(skel.Legs[1], char.Torso, char["Left Leg"], color)
                        Z_JoinNodes(skel.Legs[3], char.Torso, char["Right Leg"], color)
                        
                        -- Apagamos R15 extras
                        skel.Spine[2].Visible, skel.Arms[2].Visible, skel.Arms[4].Visible, skel.Legs[2].Visible, skel.Legs[4].Visible = false, false, false, false, false
                    end
                else
                    if Z_Skeleton_Data[player] then
                        for _, g in pairs(Z_Skeleton_Data[player]) do for _, l in pairs(g) do l.Visible = false end end
                    end
                end
            end
        end
    end)
end)

























