-- // 🔧 APLICADOR DE HACKS (LA COMBINACIÓN PERFECTA) // --
local function HackGun(v)
    if type(v) ~= "table" or not rawget(v, "gunName") then return end
    
    local gName = tostring(v.gunName):lower()
    
    -- --- 🔥 MODOS DE FUEGO PERSONALIZADOS POR ARMA ---
    if _G.Z_GunMods_Burst then
        if gName:find("hi%-point") or (gName:find("glock") and not gName:find("switch")) then
            -- RÁFAGA (BURST) para Hi-point y Glock normal
            v.ShootType = 2
            v.BurstShot = 3
            if type(v.FireModes) == "table" then
                v.FireModes.Burst = true
                v.FireModes.Semi = true
                v.FireModes.Auto = false
                v.FireModes.ChangeFiremode = true
            end
        elseif gName:find("tec%-9") or gName:find("glock switch") or gName:find("ar%-15") or gName:find("ak%-47") then
            -- AUTO (FULL AUTO) para TEC-9, Glock Switch, AR-15 y AK-47
            v.ShootType = 3
            if type(v.FireModes) == "table" then
                v.FireModes.Burst = false
                v.FireModes.Semi = true
                v.FireModes.Auto = true
                v.FireModes.ChangeFiremode = true
            end
        end
    end

    -- --- ♾️ INF AMMO TAL CUAL (SCRIPT 2) ---
    if _G.Z_GunMods_InfAmmo then
        v.AmmoInGun = math.huge 
        v.Ammo = math.huge
        v.StoredAmmo = math.huge
        v.MaxStoredAmmo = math.huge 
        if rawget(v, "Jammed") ~= nil then v.Jammed = false end
    end

    -- --- 🎯 NO RECOIL ULTRA PRO (SCRIPT 2) ---
    if _G.Z_GunMods_NoRecoil then
        v.MinSpread = 0
        v.MaxSpread = 0
        v.AimInaccuracyStepAmount = 0
        v.AimInaccuracyDecrease = 10 -- Recuperación instantánea
        
        v.MinRecoilPower = 0
        v.MaxRecoilPower = 0
        v.RecoilPowerStepAmount = 0
        v.Recoil = 0 

        -- Reseteo de Cámara
        if type(v.camRecoil) == "table" then
            v.camRecoil.camRecoilUp = {0,0}
            v.camRecoil.camRecoilTilt = {0,0}
            v.camRecoil.camRecoilLeft = {0,0}
            v.camRecoil.camRecoilRight = {0,0}
        end
        -- Reseteo del Arma
        if type(v.gunRecoil) == "table" then
            v.gunRecoil.gunRecoilUp = {0,0}
            v.gunRecoil.gunRecoilTilt = {0,0}
            v.gunRecoil.gunRecoilLeft = {0,0}
            v.gunRecoil.gunRecoilRight = {0,0}
            v.gunRecoil.DownPunch = 0
        end
    end
end

