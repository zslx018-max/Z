local function CreateQuickButton(Name, VariableName, IconID)
    -- Verificar si ya existe
    if game.CoreGui:FindFirstChild("Z_Widget_"..Name) then return end

    local Z_WidgetGui = Instance.new("ScreenGui", game.CoreGui)
    Z_WidgetGui.Name = "Z_Widget_"..Name
    
    local Holder = Instance.new("Frame", Z_WidgetGui)
    Holder.Size = UDim2.new(0, 115, 0, 35)
    Holder.Position = UDim2.new(0.5, -57, 0.2, 0) 
    Holder.BackgroundTransparency = 1 

    local MainBtn = Instance.new("TextButton", Holder)
    MainBtn.Size = UDim2.new(1, 0, 1, 0)
    MainBtn.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    MainBtn.BackgroundTransparency = 0.25 
    MainBtn.Text = "" 
    MainBtn.ClipsDescendants = true
    Instance.new("UICorner", MainBtn).CornerRadius = UDim.new(0, 8)

    -- [LAYOUT E ICONOS IGUAL QUE ANTES]
    local Layout = Instance.new("UIListLayout", MainBtn)
    Layout.FillDirection = "Horizontal"
    Layout.HorizontalAlignment = "Center"
    Layout.VerticalAlignment = "Center"
    Layout.Padding = UDim.new(0, 6)

    local Icon = Instance.new("ImageLabel", MainBtn)
    Icon.BackgroundTransparency = 1
    Icon.Size = UDim2.new(0, 18, 0, 18)
    Icon.Image = "rbxassetid://"..tostring(IconID)

    local TextLabel = Instance.new("TextLabel", MainBtn)
    TextLabel.BackgroundTransparency = 1
    TextLabel.AutomaticSize = "XY"
    TextLabel.Text = Name:upper()
    TextLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    TextLabel.Font = Enum.Font.GothamBold
    TextLabel.TextSize = 10

    local RainbowStroke = Instance.new("UIStroke", MainBtn)
    RainbowStroke.Thickness = 2.2
    local UIGradient = Instance.new("UIGradient", RainbowStroke)
    UIGradient.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)), ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)), ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0))})

    task.spawn(function()
        local angle = 0
        game:GetService("RunService").RenderStepped:Connect(function()
            angle = angle + 3 
            UIGradient.Rotation = angle
            local isActive = _G[VariableName]
            TextLabel.TextColor3 = isActive and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(150, 150, 150)
            Icon.ImageColor3 = isActive and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(150, 150, 150)
        end)
    end)

    -- // EVENTO DE CLICK (SÓLO PARA ACTIVAR) // --
    MainBtn.MouseButton1Click:Connect(function()
        _G[VariableName] = not _G[VariableName]
        _G.Z_Force_Reset = true 
        
        local s = Instance.new("Sound", game.SoundService)
        s.SoundId = "rbxassetid://120401943587131"
        s:Play()
    end)

    -- // LÓGICA DRAGGABLE MEJORADA (PC & MÓVIL) // --
    local dragging = false
    local isPressing = false
    local dragStart, startPos, holdStartTime
    local holdThreshold = 0.35 -- Tiempo para que empiece a arrastrar

    MainBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isPressing = true
            holdStartTime = tick()
            dragStart = input.Position
            startPos = Holder.Position
        end
    end)

    -- Usamos UserInputService global para detectar el movimiento aunque el mouse se salga del botón
    game:GetService("UserInputService").InputChanged:Connect(function(input)
        if isPressing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            -- Solo activamos el drag si se ha mantenido presionado el tiempo suficiente
            if (tick() - holdStartTime) >= holdThreshold then
                dragging = true
                local delta = input.Position - dragStart
                Holder.Position = UDim2.new(
                    startPos.X.Scale, 
                    startPos.X.Offset + delta.X, 
                    startPos.Y.Scale, 
                    startPos.Y.Offset + delta.Y
                )
            end
        end
    end)

    -- EL FIX REAL: Resetear todo cuando sueltas el click
    game:GetService("UserInputService").InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isPressing = false
            dragging = false
            holdStartTime = 0
        end
    end)
end























