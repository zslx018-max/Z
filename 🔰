-- MAIN LOOP (se ejecuta en segundo plano)
-- ==============================================================================
local function mainLoop()
    while true do
        task.wait(0.2)
        if autoFarm then
            pcall(function()
                refreshVars()
                if not miAsiento or not miAsiento.Parent then
                    if hum.SeatPart then
                        miAsiento = hum.SeatPart
                    else
                        AutoGetCarPremium()
                        if not miAsiento then return end
                    end
                end
                EnsureSit()

                -- FASE 3
                safeVehicleTP(CFrame.new(-1849, 1, 25), true)
                safeExitSeat(Vector3.new(-1843, 3, 8))
                task.wait(0.1)
                SmartWash()
                SmartBuy()
                EnsureSit()

                -- FASE 7
                safeVehicleTP(CFrame.new(3514, 14, -723) * CFrame.Angles(0, math.rad(26), 0), false)
                safeExitSeat(Vector3.new(3506, 4, -744))
                task.wait(0.1)
                SmartSell()
                EnsureSit()
            end)
        end
    end
end

-- Iniciar el loop principal
