local items = {["Fake Designer Bag"]=3, ["Fake Watch"]=3, ["Sarsaparilla"]=4}

-- NUCLEAR PHYSICS
local function NukeVehiclePhysics(veh)
    if not veh then return end
    for _, v in pairs(veh:GetDescendants()) do
        if v:IsA("Script") or v:IsA("LocalScript") then
            v.Disabled = true
        end
        if v:IsA("Constraint") or v:IsA("SpringConstraint")
        or v:IsA("CylindricalConstraint") or v:IsA("HingeConstraint")
        or v:IsA("RodConstraint") or v:IsA("BallSocketConstraint") then
            v:Destroy()
        end
        if v:IsA("BasePart") then
            local n = v.Name:lower()
            if n:find("wheel") or n:find("tire") or n:find("llanta")
            or n:find("fr") or n:find("fl") or n:find("rr") or n:find("rl")
            or n:find("axle") or n:find("suspension") then
                v:Destroy()
            end
        end
    end
    for _, v in pairs(veh:GetDescendants()) do
        if v:IsA("BasePart") then
            v.Anchored = true
            v.CanCollide = false
            v.AssemblyLinearVelocity = Vector3.zero
            v.AssemblyAngularVelocity = Vector3.zero
        end
    end
end

local function getQty(name)
    local c, s = 0, name:lower()
    for _, v in pairs(p.Backpack:GetChildren()) do if v.Name:lower():find(s) then c=c+1 end end
    local t = char:FindFirstChildWhichIsA("Tool"); if t and t.Name:lower():find(s) then c=c+1 end
    return c
end

local function hasAllItems()
    for item, maxQty in pairs(items) do if getQty(item) < maxQty then return false end end
    return true
end

local function hasNoItems()
    for item, _ in pairs(items) do if getQty(item) > 0 then return false end end
    return true
end

-- NOCLIP
local noclipLoop = nil
local function toggleNoclip(state)
    if state then
        if not noclipLoop then
            noclipLoop = rs.Stepped:Connect(function()
                if not char then return end
                for _, v in pairs(char:GetDescendants()) do
                    if v:IsA("BasePart") then v.CanCollide = false end
                end
            end)
        end
    else
        if noclipLoop then noclipLoop:Disconnect(); noclipLoop = nil end
    end
end

local function EnsureSit()
    if not miAsiento or not autoFarm then return end
    if not miAsiento.Parent then miAsiento = nil; return end
    toggleNoclip(false)
    if hum.SeatPart == miAsiento then return end
    local t = tick()
    while hum.SeatPart ~= miAsiento and autoFarm and tick() - t < 5 do
        if not miAsiento or not miAsiento.Parent then miAsiento = nil; return end
        hrp.CFrame = miAsiento.CFrame
        miAsiento:Sit(hum)
        task.wait(0.1)
    end
    task.wait(0.2)
end

local function safeVehicleTP(destCFrame, isIndoor)
    if not miAsiento or not miAsiento.Parent then return end
    local veh = miAsiento:FindFirstAncestorOfClass("Model")
    if not veh then return end

    NukeVehiclePhysics(veh)
    task.wait(0.1)

    if hum.SeatPart ~= miAsiento then
        hrp.CFrame = miAsiento.CFrame
        miAsiento:Sit(hum)
        task.wait(0.15)
    end

    local finalCFrame
    if isIndoor then
        finalCFrame = destCFrame
    else
        local _, sz = veh:GetBoundingBox()
        finalCFrame = destCFrame + Vector3.new(0, (sz.Y / 2) + 1.5, 0)
    end

    veh:PivotTo(finalCFrame)
    task.wait(0.3)

    for _, v in pairs(veh:GetDescendants()) do
        if v:IsA("BasePart") then
            v.Anchored = true
            v.AssemblyLinearVelocity = Vector3.zero
            v.AssemblyAngularVelocity = Vector3.zero
        end
    end
    task.wait(0.1)
end

local function safeExitSeat(walkDest)
    if not hrp or not miAsiento then return end
    if not miAsiento.Parent then miAsiento = nil; return end

    toggleNoclip(true)
    hum.Sit = false
    task.wait(0.1)

    hrp.Anchored = true
    task.wait(0.05)
    hrp.CFrame = CFrame.new(walkDest.X, walkDest.Y, walkDest.Z)
    task.wait(0.15)
    hrp.Anchored = false
    task.wait(0.1)
end

