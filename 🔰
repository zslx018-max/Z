local PlaceId = 109872214376771 -- ID de El Paso, Texas: Border RP
local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Player = game.Players.LocalPlayer

-- // 🚀 EXPORTAR A _G // --
_G.zHub = _G.zHub or {}

_G.zHub.serverHop = function()
    -- API para servidores de menor a mayor (buscando el más vacío)
    local url = "https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
    
    local success, result = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(url))
    end)

    if success and result and result.data then
        for _, server in ipairs(result.data) do
            -- Filtramos: Que no esté lleno, que no sea el server actual y que tenga espacio
            if server.playing < server.maxPlayers and server.id ~= game.JobId then
                TeleportService:TeleportToPlaceInstance(PlaceId, server.id, Player)
                return true
            end
        end
    end
    
    warn("Z-Hub: No se encontraron servidores más vacíos.")
    return false
end

