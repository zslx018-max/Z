local function forceUIClick(textoBoton)
    for _, gui in pairs(p.PlayerGui:GetDescendants()) do
        if gui:IsA("TextButton") and gui.Visible and gui.AbsolutePosition.X > 0 then
            if gui.Text:lower():find(textoBoton:lower()) then
                local x = gui.AbsolutePosition.X + (gui.AbsoluteSize.X / 2)
                local y = gui.AbsolutePosition.Y + (gui.AbsoluteSize.Y / 2) + 36
                vim:SendMouseButtonEvent(x, y, 0, true, game, 1)
                task.wait(0.05)
                vim:SendMouseButtonEvent(x, y, 0, false, game, 1)
                return true
            end
        end
    end
    return false
end

local function AutoGetCarPremium()
    if hum.SeatPart then 
        miAsiento = hum.SeatPart
        return 
    end

    local carSpawnPos = CFrame.new(-1947, 3.5, 55)
    local startTime = tick()
    local maxDuration = 15
    local lastTeleport = tick()

    while not hum.SeatPart and tick() - startTime < maxDuration and autoFarm do
        if tick() - lastTeleport >= 0.5 then
            hrp.Anchored = true
            hrp.CFrame = carSpawnPos
            hrp.Anchored = false
            lastTeleport = tick()
        end

        forceUIClick("select")
        task.wait(0.1)
        forceUIClick("spawn")
        task.wait(0.1)

        for _, obj in pairs(workspace:GetDescendants()) do
            if (obj:IsA("VehicleSeat") or obj:IsA("Seat"))
            and (obj.Position - hrp.Position).Magnitude < 30 then
                obj:Sit(hum)
                if hum.SeatPart then 
                    miAsiento = hum.SeatPart
                    return 
                end
            end
        end
        task.wait(0.2)
    end

    if not hum.SeatPart then
        task.wait(1)
        AutoGetCarPremium()
    end
end

