-- ================== FUNCIONES DE SOPORTE ==================
local function humanWait(min, max)
    task.wait(min + math.random() * (max - min))
end

local function isNear(pos, radius)
    local char = p.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    return hrp and (hrp.Position - pos).Magnitude <= (radius or 30)
end

local function isInVoid()
    local char = p.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    return hrp and hrp.Position.Y < 2
end

local function waitForChunks(center, minParts)
    minParts = minParts or 20
    local start = tick()
    repeat
        local count = 0
        for _, v in ipairs(Workspace:GetDescendants()) do
            if v:IsA("BasePart") and (v.Position - center).Magnitude < 150 then
                count += 1
            end
        end
        if count >= minParts then return true end
        task.wait(0.3)
    until tick() - start > 10
    return false
end

local function forceReset()
    if p.Character then
        p.Character:BreakJoints()
    end
    repeat task.wait(0.3) until p.Character and p.Character:FindFirstChild("HumanoidRootPart")
    task.wait(0.5)
end

-- ================== TP ROCK SOLID (8 REINTENTOS) ==================
local function rockSolidTP(targetPos, targetRot)
    local maxTries = 8
    local success = false
    
    for attempt = 1, maxTries do
        local char = p.Character
        if not char then break end
        
        local hrp = char:WaitForChild("HumanoidRootPart")
        local hum = char:WaitForChild("Humanoid")
        
        WindUI:Notify({
            Title = "TP Sólido",
            Content = "Intento "..attempt.."/"..maxTries.."...",
            Duration = 1.5,
        })
        
        -- Pre-estabilización
        hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
        hrp.Velocity = Vector3.zero
        hrp.RotVelocity = Vector3.zero
        hrp.Anchored = true
        hrp.CFrame = hrp.CFrame + Vector3.new(0, 0.5, 0)
        task.wait(0.15)
        
        local noclip = RunService.Stepped:Connect(function()
            for _, v in pairs(char:GetDescendants()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end)

        -- Bombardeo (70 paquetes)
        for _ = 1, 70 do
            hrp.CFrame = CFrame.new(targetPos) * targetRot
            RunService.Heartbeat:Wait()
        end

        hum.PlatformStand = true
        hrp.Anchored = false
        
        -- Dominación (3.0s)
        local endT = tick() + 3.0
        repeat
            hrp.CFrame = CFrame.new(targetPos) * targetRot
            hrp.Velocity = Vector3.zero
            hrp.RotVelocity = Vector3.zero
            hum.Health = hum.MaxHealth
            RunService.RenderStepped:Wait()
        until tick() > endT

        -- Corrección simple post‑TP (1.5s)
        local correctionEnd = tick() + 1.5
        repeat
            local currentPos = hrp.Position
            if currentPos.Y < 2 then
                hrp.CFrame = CFrame.new(targetPos.X, targetPos.Y, targetPos.Z) * targetRot
            elseif (currentPos - targetPos).Magnitude > 25 then
                hrp.CFrame = CFrame.new(targetPos) * targetRot
            end
            hrp.Velocity = Vector3.zero
            hrp.RotVelocity = Vector3.zero
            RunService.Heartbeat:Wait()
        until tick() > correctionEnd

        hum.PlatformStand = false
        noclip:Disconnect()
        hum:SetStateEnabled(Enum.HumanoidStateType.Dead, true)
        
        humanWait(0.3, 0.5)
        
        -- Verificación final
        if isNear(targetPos, 35) and not isInVoid() then
            waitForChunks(targetPos, 25)
            success = true
            break
        else
            hrp.CFrame = CFrame.new(targetPos) * targetRot
            task.wait(0.5)
        end
    end
    
    if success then
        WindUI:Notify({
            Title = "TP EXITOSO",
            Content = "Llegada confirmada. ¡A darle!",
            Duration = 2,
        })
    else
        WindUI:Notify({
            Title = "TP FALLIDO",
            Content = "Prueba hacer Reset manual y reintenta.",
            Duration = 3,
        })
    end
    
    return success
end

