-- ================== COORDENADAS (LAS MISMAS DE SIEMPRE) ==================
local ZONA_COMPRA_POS = Vector3.new(-1842.77, 3.24, -0.32)
local ZONA_COMPRA_ROT = CFrame.Angles(0, math.rad(-88.4), 0)

local ZONA_VENTA_POS = Vector3.new(3150.53, 2.74, -178.38)
local ZONA_VENTA_ROT = CFrame.Angles(0, math.rad(49.1), 0)

local ZONA_LAVADO_POS = Vector3.new(-1847, 3.5, -9)
local ZONA_LAVADO_ROT = CFrame.Angles(0, math.rad(-88.4), 0)

-- ================== ITEMS ==================
local ITEMS = {
    ["Fake Designer Bag"] = 3,
    ["Fake Watch"] = 3,
    ["Sarsaparilla"] = 4
}

-- ================== VARIABLES ==================
local farmActive = false
local noclipConn = nil
local char, hum, hrp
local currentState = "IDLE"
local lastStateChange = tick()
local WATCHDOG_TIMEOUT = 120  -- Más tolerante para redes lentas

-- ================== UI RAYFIELD ==================
local Window = Rayfield:CreateWindow({
    Name = "Z Hub | REDUNDANCIA 175%",
    LoadingTitle = "Inyectando Estabilidad...",
